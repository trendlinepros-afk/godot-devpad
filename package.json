{
  "name": "zirtola",
  "version": "0.1.5",
  "description": "Zirtola — The AI Video Game Editor. A local-first Godot game development companion with an integrated AI assistant.",
  "author": "Zirtola",
  "license": "MIT",
  "private": true,
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "eval:models": "node scripts/gdscript-eval.mjs",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "adm-zip": "^0.5.16",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "express": "^4.21.2",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "ws": "^8.18.0",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.6.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.zirtola.app",
    "productName": "Zirtola",
    "files": [
      "dist",
      "dist-electron",
      "godot-versions.json"
    ],
    "extraResources": [
      "godot-versions.json",
      "resources/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "trendlinepros-afk",
        "repo": "godot-devpad",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg"
    }
  }
}
